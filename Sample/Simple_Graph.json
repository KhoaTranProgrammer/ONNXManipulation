{
    "name": "Simple_Graph",
    "graph": {
        "inputs": [
            {
                "name": "X",
                "shape": [1, 2, 512, 512],
                "data_type": "float32"
            }
        ],
        "outputs": [
            {
                "name": "Y"
            }
        ],
        "nodes": [
            {
                "name": "Abs_Node",
                "op_type": "Abs",
                "inputs": ["X"],
                "outputs": ["Abs_Node_output"]
            },
            {
                "name": "Relu_Node",
                "op_type": "Relu",
                "inputs": ["Abs_Node_output"],
                "outputs": ["Relu_Node_output"]
            },
            {
                "name": "Softmax_Node",
                "op_type": "Softmax",
                "inputs": ["Relu_Node_output"],
                "outputs": ["Y"],
                "attributes": {
                    "axis": 0
                }
            }
        ]
    }
}
